{
  "name": "eduai-backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "postinstall": "npm run prisma:generate",
    "db:seed": "npm run prisma:merge && prisma db seed",
    "prisma:merge": "node scripts/merge-prisma-schema.js",
    "prisma:generate": "npm run prisma:merge && prisma generate",
    "prisma:validate": "npm run prisma:merge && prisma validate",
    "prisma:migrate:dev": "npm run prisma:merge && prisma migrate dev",
    "prisma:migrate:deploy": "npm run prisma:merge && prisma migrate deploy",
    "prisma:studio": "npm run prisma:merge && prisma studio",
    "start": "node dist/src/main",
    "start:dev": "nest start --watch",
    "test": "jest",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1087.0",
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/bcrypt": "^6.0.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "ioredis": "^5.11.1",
    "openai": "^6.47.0",
    "pg": "^8.21.0",
    "qrcode": "^1.5.4",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.8",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.17.10",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^6.0.2",
    "dotenv": "^17.4.2",
    "jest": "^29.7.0",
    "prisma": "^7.8.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
