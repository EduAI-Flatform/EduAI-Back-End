model Role {
  id          String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        RoleName   @unique
  description String?
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  users       UserRole[]

  @@map("roles")
}
